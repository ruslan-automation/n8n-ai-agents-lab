    {
      "parameters": {
        "jsCode": "const result = $input.item.json;\nconst s = $('Save Vector Task').item.json;\n\nlet imageUrl = null;\ntry {\n  if (result.data && result.data.resultJson) {\n    const parsed = JSON.parse(result.data.resultJson);\n    if (parsed.resultUrls && parsed.resultUrls.length > 0) imageUrl = parsed.resultUrls[0];\n    else if (parsed.resultUrl) imageUrl = parsed.resultUrl;\n  }\n  if (!imageUrl && result.data && result.data.resultUrl) imageUrl = result.data.resultUrl;\n  if (!imageUrl && result.data && result.data.url) imageUrl = result.data.url;\n} catch (e) {\n  throw new Error('Failed to parse KIE result: ' + e.message);\n}\nif (!imageUrl) throw new Error('No vector image URL in KIE response');\n\nreturn { json: { ...s, vector_url: imageUrl } };"
      },
