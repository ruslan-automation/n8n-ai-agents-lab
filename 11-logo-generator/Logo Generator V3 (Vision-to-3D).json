        "jsonBody": "={{ JSON.stringify({ model: 'google/gemini-2.0-flash-001', messages: [{ role: 'user', content: [{ type: 'image_url', image_url: { url: $('Extract Vector URL').item.json.vector_url } }, { type: 'text', text: 'Describe this logo icon in ONE detailed sentence for a 3D render prompt. Focus on the EXACT shape, form and visual elements. Do NOT mention colors, background or style. Example: \"a stylized flame emerging from a burger bun with curved lines and a rounded base\". Output ONLY the description, nothing else.' }] }] }) }}",
