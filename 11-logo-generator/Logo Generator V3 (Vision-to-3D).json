      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "credentials": {
        "httpBearerAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "RAG юрист  (OpenRouter)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\nconst content = response.choices[0].message.content;\nconst brainData = $('Prepare Brain Input').item.json;\n\nlet parsed;\ntry {\n  parsed = JSON.parse(content);\n} catch (e) {\n  const match = content.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n  if (match) parsed = JSON.parse(match[1].trim());\n  else throw new Error('AI did not return valid JSON');\n}\n\nif (!parsed.vector_prompt) throw new Error('Missing vector_prompt in AI response');\n\nreturn { json: { current_prompt: parsed.vector_prompt, vector_prompt: parsed.vector_prompt, brand_name: parsed.brand_name || brainData.user_input, brand_colors: parsed.brand_colors || '', chat_id: brainData.chat_id, user_input: brainData.user_input, first_name: brainData.first_name, vector_url: null, neon_url: null } };"
      },
