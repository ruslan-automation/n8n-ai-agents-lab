    {
      "parameters": {
        "jsCode": "const msg = $('Telegram Trigger').item.json.message;\nconst userInput = msg.text.trim();\nconst chat_id = msg.chat.id;\n\nconst systemPrompt = `You are a world-class Brand Identity Designer. The user describes a brand. Create ONE vector logo prompt.\n\nOutput ONLY valid JSON:\n{\"brand_name\":\"...\",\"brand_colors\":\"...\",\"vector_prompt\":\"...\"}\n\nRULES:\n- Style: Paul Rand or Saul Bass minimalism\n- Describe the icon SEMANTICALLY (what it represents), NOT geometrically\n- GOOD: \"a single, iconic symbol representing flames or a stylized burger\"\n- BAD: \"two upward pointing triangles, one slightly offset\"\n- The icon must be recognizable and relevant to the business\n- Clean geometric lines, max 2 colors + white background, centered\n- NO text, NO typography, NO letters\n- Keep prompt SHORT (1-2 sentences)`;\n\nconst requestBody = { model: 'google/gemini-2.0-flash-001', messages: [{ role: 'system', content: systemPrompt }, { role: 'user', content: userInput }] };\n\nreturn { json: { requestBody: JSON.stringify(requestBody), chat_id, user_input: userInput, first_name: msg.from?.first_name || '' } };"
      },
      "id": "v3-brain-prep",
      "name": "Prepare Brain Input",
      "position": [
        1120,
        512
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
