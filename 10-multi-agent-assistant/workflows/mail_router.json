      "id": "bf42c20d-e205-4465-a752-b978fd356d1a",
      "name": "Supabase: Get Recent History",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        816,
        352
      ],
      "credentials": {
        "supabaseApi": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Assistant"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Get data from previous nodes\nconst mergeData = $('Code: Merge Voice & Text').first().json;\nconst currentTime = $('Get Current DateTime').first().json;\n\n// Get preferences and history from merged input\nlet userPreferences = 'No preferences set';\nlet recentHistory = 'No recent history';\n\ntry {\n  const allItems = $input.all();\n  \n  // Find preferences (from first Supabase node)\n  const prefItems = allItems.filter(item => item.json.preference_type !== undefined);\n  if (prefItems.length > 0) {\n    userPreferences = prefItems.map(item => \n      item.json.preference_type + ': ' + item.json.value\n    ).join(', ');\n  }\n  \n  // Find history items (from second Supabase node)\n  const histItems = allItems.filter(item => item.json.role !== undefined && item.json.content !== undefined);\n  if (histItems.length > 0) {\n    recentHistory = histItems.slice(0, 10).map(item => \n      item.json.role + ': ' + (item.json.content || '').substring(0, 100)\n    ).join('\\n');\n  }\n} catch (e) {\n  // If error, use defaults\n}\n\nreturn [{\n  json: {\n    user_message: mergeData.user_message,\n    current_datetime: currentTime.current_datetime,\n    user_context: userPreferences,\n    recent_history: recentHistory,\n    chat_id: mergeData.chat_id,\n    user_id: mergeData.user_id,\n    username: mergeData.username\n  }\n}];"
      },
      "id": "79531daa-ab78-4682-a96d-346c6cd246f2",
