    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst triggerData = $('Telegram Trigger').first().json;\nlet userMessage = '';\n\n// Check if we have whisper output (voice path)\nconst whisperItem = items.find(item => item.json?.text);\nif (whisperItem) {\n  userMessage = whisperItem.json.text;\n} else {\n  // Text path\n  userMessage = triggerData.message?.text || '';\n}\n\nreturn [{\n  json: {\n    user_message: userMessage,\n    chat_id: triggerData.message.chat.id,\n    user_id: triggerData.message.from.id,\n    username: triggerData.message.from.username || triggerData.message.from.first_name,\n    timestamp: new Date().toISOString(),\n    source: whisperItem ? 'voice' : 'text'\n  }\n}];"
      },
      "id": "e7f35a68-c925-4309-8064-16a77b70a07d",
      "name": "Code: Merge Voice & Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        240
      ]
    },
