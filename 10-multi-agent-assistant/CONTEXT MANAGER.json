      "position": [
        -656,
        96
      ],
      "typeVersion": 1.2
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "assistant_history",
        "limit": 100,
        "filterType": "string",
        "filterString": "created_at.gte.{{ new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString() }}"
      },
      "id": "42328104-52d9-4dd9-9b32-d1fd3af663d6",
      "name": "Get Active Users",
      "type": "n8n-nodes-base.supabase",
      "position": [
        -448,
        96
      ],
      "typeVersion": 1,
      "credentials": {
        "supabaseApi": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Assistant"
        }
      },
