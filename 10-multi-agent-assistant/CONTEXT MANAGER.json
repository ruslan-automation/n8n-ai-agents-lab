    },
    {
      "parameters": {
        "options": {}
      },
      "id": "27ba17a4-2093-4750-ac11-7c9ee4aca24e",
      "name": "Loop Users",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [
        -224,
        96
      ],
      "typeVersion": 3
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst userData = items[0]?.json || {};\n\n// Анализ паттернов\nconst chatId = userData.chat_id || userData.user_id || 'unknown';\nconst intent = userData.intent || 'general';\nconst hour = new Date(userData.created_at).getHours();\n\n// Статистика\nconst patterns = {\n  chatId: chatId,\n  frequentIntents: [intent],\n  activeHours: [hour],\n  lastActivity: userData.created_at,\n  preferences: {\n    preferredHour: hour,\n    topIntent: intent\n  }\n};\n\nreturn { json: patterns };"
      },
      "id": "2f73639f-9a91-49f1-b7da-f7b608d40f28",
      "name": "Analyze Patterns",
      "type": "n8n-nodes-base.code",
      "position": [
        0,
        0
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "upsert"
      },
      "id": "36d17f1a-fc13-44a0-b35c-3afc89e2d1ae",
      "name": "Update Preferences",
      "type": "n8n-nodes-base.supabase",
      "position": [
        224,
        0
      ],
      "typeVersion": 1,
      "credentials": {
        "supabaseApi": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Assistant"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "operation": "delete",
        "tableId": "assistant_history",
        "filterType": "string",
        "filterString": "created_at.lt.{{ new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString() }}"
      },
      "id": "a92aa144-955c-4e22-91a5-da225cf98171",
      "name": "Cleanup Old Data",
      "type": "n8n-nodes-base.supabase",
      "position": [
        0,
        192
      ],
      "typeVersion": 1,
      "credentials": {
        "supabaseApi": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Assistant"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\n\nconst insights = {\n  generated_at: now.toISOString(),\n  period: 'daily',\n  summary: 'Анализ завершён',\n  cleanedRecords: 'old records removed',\n  nextRun: new Date(now.getTime() + 15 * 60 * 1000).toISOString()\n};\n\nreturn { json: insights };"
      },
      "id": "72cc77bf-f991-4e3a-9133-978ed0bf4e5a",
      "name": "Generate Insights",
      "type": "n8n-nodes-base.code",
      "position": [
        224,
        192
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "tableId": "proactivity_insights",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "insight_type",
              "fieldValue": "system_maintenance"
            },
            {
              "fieldId": "description",
              "fieldValue": "={{ $json.summary }}. Статус: {{ $json.cleanedRecords }}"
            },
            {
              "fieldId": "user_id",
              "fieldValue": "={{ $('Loop Users').item.json.chatId }}"
            }
          ]
        }
      },
      "id": "0eec1a03-1fbb-4df2-8797-86379f08a4ef",
      "name": "Save Insights",
      "type": "n8n-nodes-base.supabase",
      "position": [
