        }
      }
    },
    {
      "parameters": {
        "jsCode": "const contacts = $input.all();\nconst originalData = $('Parse Recipients').item.json;\n\nif (contacts.length === 0) {\n  return {\n    json: {\n      ...originalData,\n      email: null,\n      contactFound: false,\n      error: `Контакт \"${originalData.recipientValue}\" не найден в базе данных`\n    }\n  };\n}\n\nconst contact = contacts[0].json;\nreturn {\n  json: {\n    ...originalData,\n    email: contact.email,\n    contactName: contact.name || contact.username,\n    contactFound: true\n  }\n};"
      },
      "id": "cd953ac1-be3e-4e3a-97d7-7e06e80a1a56",
      "name": "Process Contact Result",
      "type": "n8n-nodes-base.code",
      "position": [
