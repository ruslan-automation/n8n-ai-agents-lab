        "limit": 5,
        "filterType": "string",
        "filterString": "=name.ilike.%{{ $json.recipientValue }}%,username.ilike.%{{ $json.recipientValue }}%,telegram.ilike.%{{ $json.recipientValue }}%"
      },
      "id": "ead393f3-e9a5-4a2f-a787-f1bbc06a24ae",
      "name": "Supabase Search Contact",
      "type": "n8n-nodes-base.supabase",
      "position": [
        -1296,
