    {
      "parameters": {
        "jsCode": "const callback = $input.item.json.body?.callback_query || $input.item.json.callback_query || {};\nconst data = callback.data || '';\nconst chatId = callback.message?.chat?.id || '';\nconst messageId = callback.message?.message_id || '';\nconst queryId = callback.id || '';\n\n// Parse callback data: email_send_DRAFT_ID, email_edit_DRAFT_ID, email_cancel_DRAFT_ID\nconst parts = data.split('_');\nconst action = parts[1] || 'unknown';\nconst draftId = parts.slice(2).join('_') || '';\n\nreturn {\n  json: {\n    action,\n    draftId,\n    chatId,\n    messageId,\n    queryId,\n    rawData: data\n  }\n};"
      },
