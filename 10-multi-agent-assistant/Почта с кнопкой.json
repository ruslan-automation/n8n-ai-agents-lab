    {
      "parameters": {
        "jsCode": "// Parse recipients: supports \"Игорю\", \"igor@mail.ru\", \"@igor\"\n// Works with both Execute Workflow Trigger and Webhook\nconst input = $input.item.json.body || $input.item.json;\nconst recipient = input.recipient || input.to || '';\nconst command = input.command || input.message || '';\n\n// Determine recipient type\nlet recipientType = 'unknown';\nlet recipientValue = recipient.trim();\nlet needsLookup = false;\n\nif (recipientValue.includes('@') && recipientValue.includes('.')) {\n  // Direct email: igor@mail.ru\n  recipientType = 'email';\n  needsLookup = false;\n} else if (recipientValue.startsWith('@')) {\n  // Telegram/username: @igor\n  recipientType = 'username';\n  recipientValue = recipientValue.slice(1);\n  needsLookup = true;\n} else if (recipientValue.length > 0) {\n  // Name: \"Игорю\", \"Igor\"\n  recipientType = 'name';\n  // Remove common Russian dative endings\n  recipientValue = recipientValue.replace(/(у|ю|е)$/i, '');\n  needsLookup = true;\n}\n\nreturn {\n  json: {\n    originalRecipient: recipient,\n    recipientType,\n    recipientValue,\n    needsLookup,\n    command,\n    action: input.action || 'draft',\n    subject: input.subject || '',\n    body: input.body || '',\n    attachments: input.attachments || [],\n    chatId: input.chatId || input.chat_id || '',\n    userId: input.userId || input.user_id || ''\n  }\n};"
      },
      "id": "7edb84ef-8807-4539-b824-8a612617b595",
      "name": "Parse Recipients",
      "type": "n8n-nodes-base.code",
      "position": [
        -1728,
