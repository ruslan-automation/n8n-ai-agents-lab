      "parameters": {
        "jsCode": "const draft = $input.item.json;\nconst originalData = $('Process Agent Output').item.json;\n\nconst draftId = draft.id || draft.draftId || '';\nconst draftLink = `https://mail.google.com/mail/u/0/#drafts?compose=${draftId}`;\n\nreturn {\n  json: {\n    draftId,\n    draftLink,\n    subject: originalData.subject,\n    to: originalData.to,\n    body: originalData.body,\n    chatId: originalData.chatId,\n    userId: originalData.userId,\n    action: 'draft_created'\n  }\n};"
