    {
      "parameters": {
        "promptType": "define",
        "text": "=Пользователь хочет отправить email.\n\nПолучатель: {{ $json.contactName }} <{{ $json.email }}>\nКоманда пользователя: {{ $json.command }}\nДействие: {{ $json.action }}\n\nСгенерируй профессиональное письмо и верни ТОЛЬКО JSON:\n{\n  \"action\": \"send\",\n  \"subject\": \"тема письма\",\n  \"body\": \"текст письма\",\n  \"to\": \"{{ $json.email }}\"\n}",
        "options": {
          "systemMessage": "Ты - email-ассистент. Генерируй профессиональные письма.\n\nПРАВИЛА:\n1. Отвечай ТОЛЬКО валидным JSON\n2. Никакого текста до или после JSON\n3. action всегда 'send' если не указано иначе\n4. body - полный текст письма с приветствием и подписью\n\nПример ответа:\n{\"action\": \"send\", \"subject\": \"Привет\", \"body\": \"Здравствуйте!\\n\\nТекст письма.\\n\\nС уважением\", \"to\": \"email@example.com\"}",
          "maxIterations": 3
        }
      },
      "id": "a9cc1323-cbc5-43e5-9813-e4b5450b3c84",
      "name": "Email AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        -720,
        128
      ],
      "typeVersion": 3.1,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const agentOutput = $input.item.json;\nconst originalData = $('IF Contact Found').item.json;\n\n// Parse agent output\nlet emailData;\ntry {\n  // Try to extract JSON from agent response\n  const outputText = agentOutput.output || agentOutput.text || JSON.stringify(agentOutput);\n  const jsonMatch = outputText.match(/\\{[\\s\\S]*\\}/);\n  emailData = jsonMatch ? JSON.parse(jsonMatch[0]) : agentOutput;\n} catch (e) {\n  emailData = {\n    action: originalData.action || 'draft',\n    subject: agentOutput.subject || originalData.subject || 'No Subject',\n    body: agentOutput.body || agentOutput.output || '',\n    to: originalData.email\n  };\n}\n\nreturn {\n  json: {\n    action: emailData.action || originalData.action || 'draft',\n    subject: emailData.subject || originalData.subject,\n    body: emailData.body || emailData.message || '',\n    to: emailData.to || originalData.email,\n    contactName: originalData.contactName,\n    chatId: originalData.chatId,\n    userId: originalData.userId,\n    originalCommand: originalData.command\n  }\n};"
      },
