      "id": "3d0b2a0e-74ea-4f44-9110-d433bc684fd9",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "position": [
        -944,
        96
      ],
      "typeVersion": 1.1
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst now = new Date();\n\nconst months = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];\n\nconst formatDate = (d) => `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;\nconst formatISO = (d) => d.toISOString().split('T')[0];\n\nconst tomorrow = new Date(now); tomorrow.setDate(now.getDate() + 1);\nconst nextWeek = new Date(now); nextWeek.setDate(now.getDate() + 7);\n\nconst command = input.command || '';\nlet suggestedPriority = 'medium';\nif (command.toLowerCase().includes('срочно') || command.toLowerCase().includes('важно')) {\n  suggestedPriority = 'high';\n}\n\nreturn {\n  json: {\n    command: command,\n    context: {\n      currentDate: formatDate(now),\n      today: formatISO(now),\n      tomorrow: formatISO(tomorrow),\n      nextWeek: formatISO(nextWeek),\n      suggestedPriority: suggestedPriority\n    }\n  }\n};"
      },
      "id": "d596b9f9-31a6-486b-b498-df89274bdefd",
      "name": "Inject Context",
      "type": "n8n-nodes-base.code",
      "position": [
        -736,
        96
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.command }}\n\n---\n📅 КОНТЕКСТ:\n• Сегодня: {{ $json.context.currentDate }} ({{ $json.context.today }})\n• Завтра: {{ $json.context.tomorrow }}\n• Через неделю: {{ $json.context.nextWeek }}\n• Предлагаемый приоритет: {{ $json.context.suggestedPriority }}",
        "options": {
          "systemMessage": "Ты — AI-ассистент для управления задачами в Notion. Ты помогаешь создавать, искать и управлять задачами.\n\n## 🎯 ТВОИ ВОЗМОЖНОСТИ\n\n### ➕ Создание задач\n- \"Задача: купить молоко\"\n- \"Добавь задачу отправить отчёт до завтра, срочно\"\n- \"Напомни позвонить в банк через неделю\"\n\n### 📋 Просмотр задач\n- \"Покажи мои задачи\"\n- \"Что надо сделать сегодня?\"\n- \"Какие срочные задачи?\"\n\n### ✏️ Редактирование\n- \"Отметь задачу 'купить молоко' выполненной\"\n- \"Перенеси дедлайн на пятницу\"\n- \"Сделай задачу срочной\"\n\n## 🏠 СТРУКТУРА ЗАДАЧИ В NOTION\n- title: Название задачи\n- status: To Do / In Progress / Done\n- priority: high / medium / low\n- due_date: Дедлайн (YYYY-MM-DD)\n- category: work / personal / shopping / health\n\n## ПРАВИЛА\n1. Приоритет по умолчанию: medium\n2. 'срочно', 'важно', 'asap' → priority: high\n3. 'когда-нибудь', 'не срочно' → priority: low\n4. 'завтра' → используй дату из контекста\n5. Отвечай кратко на русском\n\n## ВАЖНО\n- ВСЕГДА используй инструменты для работы с задачами\n- При создании high priority задачи добавь в ответ: [URGENT]\n- При ошибках объясни проблему",
          "maxIterations": 10
        }
      },
      "id": "1137d5fb-d02a-432e-8330-bab7d31970bc",
