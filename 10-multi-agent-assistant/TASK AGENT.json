        96
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const error = $input.item.json;\nconst source = $('Inject Context').item.json.source;\n\nreturn {\n  json: {\n    success: false,\n    message: 'Произошла ошибка при работе с задачами. Попробуйте ещё раз.',\n    source: source,\n    canRetry: true\n  }\n};"
      },
      "id": "8af466aa-d3c2-4e18-8a6d-c6238ac0f4c8",
      "name": "Format Error",
      "type": "n8n-nodes-base.code",
      "position": [
