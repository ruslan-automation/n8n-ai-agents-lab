    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst agentOutput = items[0]?.json || {};\nconst source = $('Inject Context').item.json.source;\n\nlet message = agentOutput.output || agentOutput.text || '';\n// Убираем маркер [URGENT] из ответа пользователю\nmessage = message.replace('[URGENT]', '').trim();\n\nreturn {\n  json: {\n    success: true,\n    message: message,\n    source: source,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "b32f2988-8c4c-4620-b9d9-bffe45d435e9",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "position": [
